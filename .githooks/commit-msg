#!/usr/bin/env bash
set -euo pipefail

msg_file="${1:?commit message file is required}"

PYTHON3=$(command -v python3 2>/dev/null || command -v python 2>/dev/null || echo "")
if [ -z "$PYTHON3" ]; then
    echo "Warning: python not found, skipping commit-msg suffix check" >&2
    exit 0
fi

"$PYTHON3" - "$msg_file" <<'PY'
from pathlib import Path
import sys

path = Path(sys.argv[1])
text = path.read_text(encoding="utf-8")
lines = text.splitlines()

suffix = " _FernandoClaude"
skip_prefixes = ("Merge ", "Revert ", "fixup! ", "squash! ")

for i, line in enumerate(lines):
    stripped = line.strip()
    if not stripped or stripped.startswith("#"):
        continue
    if stripped.startswith(skip_prefixes) or stripped.endswith(suffix):
        break
    lines[i] = line.rstrip() + suffix
    path.write_text("\n".join(lines) + ("\n" if text.endswith("\n") else ""), encoding="utf-8")
    break
PY
