# Supabase — copia este archivo a .env.local y rellena con tus credenciales
# Las encuentras en: https://supabase.com/dashboard → tu proyecto → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# Google OAuth — necesarias para refrescar el access token de Google Calendar/Gmail
# cuando caduca (cada hora). Usa las MISMAS credenciales que ya tienes configuradas
# en Supabase → Auth → Providers → Google. Si faltan, las cookies se quedan obsoletas
# y los endpoints /api/google/* dejarán de devolver datos al cabo de una hora.
GOOGLE_CLIENT_ID=tu-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-google-client-secret
# Mismo Client ID, expuesto al navegador para el botón Google Identity Services
NEXT_PUBLIC_GOOGLE_CLIENT_ID=tu-google-client-id.apps.googleusercontent.com
