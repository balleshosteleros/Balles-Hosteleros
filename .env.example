# ============================================================================
# Balles-Hosteleros — variables de entorno
# Copiar a .env.local y rellenar con valores reales. NO commitear .env.local.
# ============================================================================

# ---------- Supabase ----------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------- URLs de la app ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
APP_PRIMARY_HOSTS=localhost:3000

# ---------- Dev / Demo ----------
NEXT_PUBLIC_DEV_BYPASS_AUTH=
DEMO_EMAIL=
DEMO_PASSWORD=

# ---------- IA (Gemini / OpenRouter) ----------
GEMINI_API_KEY=
GEMINI_MODEL=
OPENROUTER_API_KEY=

# ---------- Email transaccional (Resend) ----------
RESEND_API_KEY=
RESEND_FROM_EMAIL=
EMAIL_FROM=

# ---------- Storage (Cloudflare R2) ----------
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_PUBLIC_URL=

# ---------- Banking / PSD2 (GoCardless) ----------
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=
BANK_TOKENS_KEY=

# ---------- Google OAuth ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Mismo valor que GOOGLE_CLIENT_ID, expuesto al navegador para el botón de
# Google Identity Services (One Tap / "Iniciar sesión como ...") en /login.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ---------- Meta (Facebook / Instagram Ads) ----------
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_API_VERSION=
META_INSTAGRAM_ACTOR_ID=
META_PAGE_ID=

# ---------- WhatsApp Cloud API ----------
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=
WHATSAPP_PHONE_NUMBER_ID=

# ---------- Agora (videollamadas) ----------
AGORA_API_TOKEN=
AGORA_API_URL=

# ---------- Seguridad / Secrets ----------
CRON_SECRET=
QR_UPLOAD_SECRET=
TURNSTILE_SECRET=
CARTA_LIKE_SALT=
PAGINA_WEB_IP_SALT=

# ---------- Rate limits (Presentaciones) ----------
PRESENTACIONES_COOLDOWN_SEG=
PRESENTACIONES_MAX_POR_DIA=
PRESENTACIONES_MAX_POR_USUARIO_DIA=
